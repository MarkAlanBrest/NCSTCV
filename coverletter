"use client";
import { useState } from "react";
import { useRouter } from "next/navigation";

export default function CoverLetterPage() {
  const router = useRouter();
  const [loading, setLoading] = useState(false);

  const [formData, setFormData] = useState({
    company: "",
    jobTitle: "",
    hiringManager: "",
    jobPosting: "",
    website: "",
    whyJob: "",
    whyFit: "",
    skills: ""
  });

  function handleChange(e) {
    setFormData({
      ...formData,
      [e.target.name]: e.target.value
    });
  }

  async function handleSubmit() {
    setLoading(true);

    const res = await fetch("/api/generate-cover-letter", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify(formData)
    });

    const data = await res.json();

    localStorage.setItem("generatedCoverLetter", data.letter);
    setLoading(false);
    router.push("/cover-letter/result");
  }

  return (
    <div style={styles.page}>
      <div style={styles.container}>
        <h1 style={styles.title}>AI Cover Letter Builder</h1>

        <h3 style={styles.section}>Employer Information</h3>

        <input name="company" placeholder="Company Name" onChange={handleChange} style={styles.input} />
        <input name="jobTitle" placeholder="Job Title" onChange={handleChange} style={styles.input} />
        <input name="hiringManager" placeholder="Hiring Manager (Optional)" onChange={handleChange} style={styles.input} />
        <input name="website" placeholder="Company Website (Optional)" onChange={handleChange} style={styles.input} />

        <textarea
          name="jobPosting"
          placeholder="Paste the Job Posting Here"
          onChange={handleChange}
          style={styles.textareaLarge}
        />

        <h3 style={styles.section}>About You</h3>

        <textarea
          name="whyJob"
          placeholder="Why do you want this job?"
          onChange={handleChange}
          style={styles.textarea}
        />

        <textarea
          name="whyFit"
          placeholder="Why are you a good fit?"
          onChange={handleChange}
          style={styles.textarea}
        />

        <textarea
          name="skills"
          placeholder="List 2–3 skills to highlight"
          onChange={handleChange}
          style={styles.textarea}
        />

        <button onClick={handleSubmit} style={styles.button} disabled={loading}>
          {loading ? "Generating..." : "Generate Cover Letter"}
        </button>
      </div>
    </div>
  );
}

const styles = {
  page: {
    display: "flex",
    justifyContent: "center",
    padding: "40px 20px"
  },
  container: {
    width: "100%",
    maxWidth: "700px",
    display: "flex",
    flexDirection: "column",
    gap: "15px"
  },
  title: {
    textAlign: "center",
    fontSize: "28px",
    marginBottom: "10px"
  },
  section: {
    marginTop: "20px"
  },
  input: {
    padding: "10px",
    fontSize: "14px"
  },
  textarea: {
    padding: "10px",
    minHeight: "80px",
    fontSize: "14px"
  },
  textareaLarge: {
    padding: "10px",
    minHeight: "150px",
    fontSize: "14px"
  },
  button: {
    marginTop: "20px",
    padding: "12px",
    fontSize: "16px",
    backgroundColor: "#0b3c6d",
    color: "white",
    border: "none",
    cursor: "pointer"
  }
};